GEMINI_API_KEY=your_gemini_api_key_here
GROK_API_KEY=your_xai_grok_key_here
DEFAULT_PROVIDER=gemini

# PostgreSQL connection string — required, no default to avoid credential leaks
DATABASE_URL=postgresql://examgpt_user:your_password_here@localhost:5433/examgpt

# Frontend origin for CORS — must match your frontend's URL exactly
FRONTEND_ORIGIN=http://localhost:5173
